{
  "name": "jka-rcon-bridge-bot",
  "version": "1.0.0",
  "description": "Discord bot to bridge commands to Star Wars Jedi Academy RCON server",
  "main": "bot.js",
  "scripts": {
    "start": "node bot.js",
    "dev": "nodemon bot.js",
    "pm2:start": "pm2 start bot.js --name mbii-bot",
    "pm2:stop": "pm2 stop mbii-bot",
    "pm2:restart": "pm2 restart mbii-bot",
    "pm2:logs": "pm2 logs mbii-bot",
    "pm2:list": "pm2 list"
  },
  "dependencies": {
    "discord.js": "^14.14.1",
    "pm2": "^7.0.1"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  },
  "license": "MIT"
}
